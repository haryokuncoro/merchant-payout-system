# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5433/payout_system
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Kafka Configuration
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Stripe Configuration - Singapore
STRIPE_API_KEY_SG=sk_test_your_sg_key_here

# Stripe Configuration - HongKong
STRIPE_API_KEY_HK=sk_test_your_hk_key_here

# Stripe Configuration - Malaysia
STRIPE_API_KEY_MY=sk_test_your_my_key_here

# Stripe Configuration - US
STRIPE_API_KEY_US=sk_test_your_us_key_here

# Stripe Webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Mock Settings (for Docker)
STRIPE_MOCK_ENABLED=true
STRIPE_MOCK_BASE_URL=http://stripe-mock:12111
STRIPE_SKIP_SIGNATURE_CHECK=true

